# ESP32 WebSocket server (replace with your device IP)
NEXT_PUBLIC_ESP32_WS_URL=ws://192.168.1.XXX:81

# AI prediction API (Python Flask on laptop)
NEXT_PUBLIC_AI_PREDICT_URL=http://localhost:5000/predict

# Optional: Supabase for auth (login/register)
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
